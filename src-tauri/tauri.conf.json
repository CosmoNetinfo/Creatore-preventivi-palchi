{
  "productName": "EasyEvent",
  "version": "1.2.14",
  "identifier": "com.easyevent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EasyEvent - Gestione Preventivi",
        "width": 1280,
        "height": 800,
        "visible": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4QzYwQzRBMkZFQTk5OApSV1NZcWY2aXhHQ01CZFArMkw4N01CUXRwY3FEMHg5TUpxclZoK201TEJPdHJ2RXdtUVFsVGJnUgo=",
      "endpoints": [
        "https://github.com/CosmoNetinfo/Creatore-preventivi-palchi/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",

{
  "productName": "EasyEvent",
  "version": "1.0.0",
  "identifier": "com.easyevent.desktop",
  "build": {
    "beforeDevCommand": "cmd /c npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cmd /c npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EasyEvent - Gestione Preventivi",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
